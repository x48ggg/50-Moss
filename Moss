RunService.PreSimulation:Connect(function()
    if not _rootPart or not _humanoid then return end
    local ball = getBall()
    if not ball then return end

    local ballPos = ball.Position
    local rootPos = _rootPart.Position
    local dx = ballPos.X - rootPos.X
    local dz = ballPos.Z - rootPos.Z
    if abs(dx) > 14 or abs(dz) > 14 then return end

    local isJumping = _humanoid.FloorMaterial == MAT_AIR
    recordBall(ball)

    local currentFrame = {
        position = ballPos,
        velocity = ball.AssemblyLinearVelocity,
        time = clock()
    }
    storePrestim(currentFrame)
    storePresim(currentFrame)

    local dy = ballPos.Y - rootPos.Y
    local rawDist = sqrt(dx*dx + dy*dy + dz*dz)
    local ahead = cachedPing + INV60

    local predPos, predVel
    if cachedPing >= HIGH_PING_MS or rawDist >= 7 then
        predPos, predVel = smartPredict(ball, ahead)
    else
        predPos = ballPos
        predVel = ball.AssemblyLinearVelocity
    end

    if prestim_len >= 2 then
        local prestim_pred = getPresimPrediction(currentFrame)
        predPos = (predPos + prestim_pred.position) * 0.5
        predVel = (predVel + prestim_pred.velocity) * 0.5
    end

    local pvx, pvy, pvz = predVel.X, predVel.Y, predVel.Z

    local fpx = predPos.X + pvx*INV60
    local fpy = predPos.Y + pvy*INV60 + GRAV_HALF_SQ
    local fpz = predPos.Z + pvz*INV60

    local dx_pred = predPos.X - rootPos.X
    local dy_pred = predPos.Y - rootPos.Y
    local dz_pred = predPos.Z - rootPos.Z
    local fdx = fpx - rootPos.X
    local fdy = fpy - rootPos.Y
    local fdz = fpz - rootPos.Z

    if rawDist < INSIDE_THRESH then
        local now = clock()
        if now - lastInsideTime >= INSIDE_CD then
            lastInsideTime = now
            fireInsideBurst(ball)
        end
    end

    if isJumping then
        local dynX, dynZ, dynY = calcDynamicReach(ballPos.Y, pvx, pvy, pvz, rootPos.Y)

        local inHeader = (dy_pred > 0.8 and abs(dx_pred) <= dynX and abs(dz_pred) <= dynZ and dy_pred <= dynY)
                      or (fdy > 0.8 and abs(fdx) <= dynX and abs(fdz) <= dynZ and fdy <= dynY)

        if inHeader then
            local headPart = _head or _rootPart
            pcall(fti, ball, headPart, 0); pcall(fti, ball, headPart, 1)

            local headPos = _head and _head.Position or rootPos
            local rootVel = _rootPart.AssemblyLinearVelocity
            local phx_base = headPos.X + rootVel.X*ahead
            local phy_base = headPos.Y + rootVel.Y*ahead
            local phz_base = headPos.Z + rootVel.Z*ahead

            local phx = predPos.X - phx_base
            local phy = predPos.Y - phy_base
            local phz = predPos.Z - phz_base
            local predHDSq = phx*phx + phy*phy + phz*phz

            local fhx = fpx - phx_base
            local fhy = fpy - phy_base
            local fhz = fpz - phz_base
            local farHDSq = fhx*fhx + fhy*fhy + fhz*fhz

            local toHX = phx_base - predPos.X
            local toHY = phy_base - predPos.Y
            local toHZ = phz_base - predPos.Z
            local toHL = sqrt(toHX*toHX + toHY*toHY + toHZ*toHZ)
            local convergence = 0
            if toHL > 0.001 then
                local iLen = 1 / toHL
                convergence = pvx*(toHX*iLen) + pvy*(toHY*iLen) + pvz*(toHZ*iLen)
            end
            local convBonus = clamp(convergence * (1/40), 0, 1) * 0.9
            local effR = (1.6 + convBonus) * 0.75
            local effContactSq = effR * effR

            if predHDSq <= effContactSq or farHDSq <= effContactSq then
                if not headerActive then
                    headerActive = true
                    setFlag(1, true)
                end
                if not headerTouching then
                    headerTouching = true
                    pcall(function()
                        local cur = ball.AssemblyLinearVelocity
                        if cur.Magnitude < 80 then
                            local look = Camera.CFrame.LookVector
                            local fallSpd = max(-cur.Y, 0)
                            local boost = clamp(fallSpd * (1/40), 0, 1)
                            local power = HEADER_POWER * (1 + boost * 2.5)
                            ball.AssemblyLinearVelocity = V3(look.X*power*60, cur.Y, look.Z*power*60)
                        end
                    end)
                end
            else
                headerTouching = false
                if headerActive then headerActive = false; setFlag(1, false) end
            end
        else
            if headerActive then headerActive = false; setFlag(1, false) end
            headerTouching = false
        end

        local inVolley = (abs(dx_pred) <= VOLLEY_REACH and abs(dz_pred) <= VOLLEY_REACH and abs(dy_pred) <= VOLLEY_REACH_Y)
                      or (abs(fdx) <= VOLLEY_REACH and abs(fdz) <= VOLLEY_REACH and abs(fdy) <= VOLLEY_REACH_Y)

        if inVolley then
            fireLegTouch(ball)
            if rawDist <= 3.5 then
                if not airLegActive then
                    airLegActive = true
                    setFlag(2, true)
                end
                airLegTouching = true
            else
                if airLegTouching then
                    airLegTouching = false; airLegActive = false
                    setFlag(2, false)
                end
            end
        else
            if airLegActive then
                airLegActive = false; airLegTouching = false
                setFlag(2, false)
            end
        end
    else
        if headerActive then headerActive = false; setFlag(1, false) end
        if airLegActive then airLegActive = false; setFlag(2, false) end
        headerTouching = false; airLegTouching = false

        local inGround = (abs(dx_pred) <= GROUND_REACH and abs(dz_pred) <= GROUND_REACH and abs(dy_pred) <= GROUND_REACH)
                      or (abs(fdx) <= GROUND_REACH and abs(fdz) <= GROUND_REACH and abs(fdy) <= GROUND_REACH)
        if inGround then
            fireLegTouch(ball)
        end
    end
end)


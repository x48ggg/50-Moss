-- FIX: Ring-buffer push for prestim (no table.remove O(n) shift)
local function storePrestim(data)
    prestim_head = (prestim_head % PREMAX) + 1
    local s = prestim_buffer[prestim_head]
    s.position = data.position
    s.velocity = data.velocity
    s.time = data.time
    if prestim_len < PREMAX then prestim_len = prestim_len + 1 end
end

-- FIX: Ring-buffer push for presim
local function storePresim(data)
    presim_head = (presim_head % PMAX) + 1
    local s = presim_buffer[presim_head]
    s.position = data.position
    s.velocity = data.velocity
    s.time = data.time
    if presim_len < PMAX then presim_len = presim_len + 1 end
end

local function getPresimPrediction(current)
    if presim_len < 2 then return current end
    local avgX, avgY, avgZ = 0, 0, 0
    for i = 1, presim_len do
        local v = presim_buffer[i].velocity
        avgX = avgX + v.X
        avgY = avgY + v.Y
        avgZ = avgZ + v.Z
    end
    local inv = 1 / presim_len
    local avg_vel = V3(avgX*inv, avgY*inv, avgZ*inv)
    local tr = core_cfg.tick_rate
    return {
        position = current.position + avg_vel * tr,
        velocity = avg_vel
    }
end

-- Main Heartbeat (ping update + dribble + high-ping touch)
RunService.Heartbeat:Connect(function()
    local now = clock()
    local ball = getBall()
    if now - lastPingTime >= 2 then
        lastPingTime = now
        cachedPing = clamp(LocalPlayer:GetNetworkPing(), 0.016, 0.25)
    end

    if dribbleQueue > 0 and (now - lastDribbleTime) >= DRIBBLE_CD then
        lastDribbleTime = now
        if ball and _rootPart then
            local bp = ball.Position
            local rp = _rootPart.Position
            local dx = bp.X - rp.X
            local dy = bp.Y - rp.Y
            local dz = bp.Z - rp.Z
            if dx*dx + dy*dy + dz*dz > DRIBBLE_DIST_SQ then
                dribbleQueue = 0
            else
                fireDribbleBurst(ball)
                if _humanoid and _humanoid.FloorMaterial == MAT_AIR and _head then
                    local hp = _head.Position
                    local hdx = bp.X - hp.X
                    local hdy = bp.Y - hp.Y
                    local hdz = bp.Z - hp.Z
                    if hdx*hdx + hdy*hdy + hdz*hdz <= 9 then
                        pcall(fti, ball, _head, 0); pcall(fti, ball, _head, 1)
                    end
                end
                dribbleQueue = dribbleQueue - 1
            end
        else
            dribbleQueue = 0
        end
    end

    if cachedPing >= HIGH_PING_MS and ball and _rootPart then
        local bp = ball.Position
        local bv = ball.AssemblyLinearVelocity
        local rp = _rootPart.Position
        local ext = cachedPing * 0.6
        local ps = clamp((cachedPing - HIGH_PING_MS) * 10, 0, 1)
        local spx = bp.X + bv.X*ext - rp.X
        local spy = bp.Y + bv.Y*ext - rp.Y
        local spz = bp.Z + bv.Z*ext - rp.Z
        local gr = GROUND_REACH + ps * 1.5
        if abs(spx) <= gr and abs(spy) <= gr and abs(spz) <= gr then
            fireLegTouch(ball)
        end
        if _humanoid and _humanoid.FloorMaterial == MAT_AIR then
            local vr = VOLLEY_REACH + ps * 1.5
            if abs(spx) <= vr and abs(spz) <= vr and abs(spy) <= vr then
                fireLegTouch(ball)
            end
            if _head then
                local hp = _head.Position
                local shx = bp.X + bv.X*ext - hp.X
                local shy = bp.Y + bv.Y*ext - hp.Y
                local shz = bp.Z + bv.Z*ext - hp.Z
                local hr = (1.6 + ps * 0.6) * 0.75
                if shx*shx + shy*shy + shz*shz <= hr*hr then
                    pcall(fti, ball, _head, 0); pcall(fti, ball, _head, 1)
                end
            end
        end
    end
end)

RunService.Stepped:Connect(function()
    local ball = getBall()

local trackedBalls = {}

local function trackBall(ball)
    if trackedBalls[ball] then return end
    trackedBalls[ball] = true
end

-- FIX: scanAndTrack removed from the loop — DescendantAdded handles new balls already
-- Only run once at startup
local function scanAndTrack()
    for _, v in pairs(Workspace:GetDescendants()) do
        if v:IsA("BasePart") and v.Name == "TPS" then trackBall(v) end
    end
end

local wc = Workspace.DescendantAdded:Connect(function(d)
    if d:IsA("BasePart") and d.Name == "TPS" then task.defer(function() trackBall(d) end) end
end)
